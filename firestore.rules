rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // A user can only access their own user document and subcollections (profile, settings, workspaces, reports, templates, aiHistory)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId);
    }
  }
}
